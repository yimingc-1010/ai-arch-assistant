# ──────────────────────────────────────────────
# lawrag — 法規 PDF RAG 系統
# ──────────────────────────────────────────────

# Voyage AI（主要 embedding，法律文件專用）
# 取得：https://www.voyageai.com/
VOYAGE_API_KEY=

# Anthropic Claude（主要 LLM）
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI（選填，可切換為 embedding 或 LLM 替代方案）
# 取得：https://platform.openai.com/
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# lawrag 設定（以下皆有預設值，可省略）
# ──────────────────────────────────────────────

# ChromaDB 持久化目錄（預設：./data/chroma）
# LAWRAG_CHROMA_DIR=./data/chroma

# Embedding provider：voyage | openai（預設：voyage）
# LAWRAG_EMBEDDING_PROVIDER=voyage

# LLM provider：anthropic | openai（預設：anthropic）
# LAWRAG_LLM_PROVIDER=anthropic
